# Which LLM provider the router uses. Milestone 1 supports only "ollama".
LLM_PROVIDER=ollama

# Local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# Required — no in-code default. Set this to a model you've pulled, e.g.:
#   ollama pull llama3.1
OLLAMA_MODEL=qwen2.5:3b

# Comma-separated origins allowed to call the API (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000


