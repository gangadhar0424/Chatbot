# Which LLM provider the router uses: "ollama" (local dev) or "openai" (prod).
LLM_PROVIDER=ollama

# Local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# Required — no in-code default. Set this to a model you've pulled, e.g.:
#   ollama pull llama3.1
OLLAMA_MODEL=qwen2.5:3b

# Comma-separated origins allowed to call the API (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000

# OpenAI-compatible provider (used when LLM_PROVIDER=openai).
# OPENAI_BASE_URL defaults to https://api.openai.com/v1; override to point at
# Groq, Together, or any other compatible host.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=120

# Postgres connection string (Neon or any standard Postgres).
# Must include ?sslmode=require for Neon. channel_binding is stripped
# automatically — asyncpg handles SCRAM channel binding implicitly over SSL.
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
